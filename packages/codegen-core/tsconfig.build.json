{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": false,
    "incremental": false,
    "moduleResolution": "node",
    "paths": {}
  },
  "include": ["src/**/*"],
  "exclude": ["tests/**/*", "dist/**/*", "**/*.spec.ts"]
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@plccopilot/codegen-codesys": ["../codegen-codesys/src/index.ts"],
      "@plccopilot/codegen-core": ["../codegen-core/src/index.ts"],
      "@plccopilot/codegen-rockwell": ["../codegen-rockwell/src/index.ts"],
      "@plccopilot/codegen-siemens": ["../codegen-siemens/src/index.ts"],
      "@plccopilot/pir": ["../pir/src/index.ts"]
    }
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist", "src/types/external-shims.d.ts"]
}

<?xml version="1.0" encoding="UTF-8"?>
<!--
  Anonymised, representative Beckhoff/TwinCAT ECAD Import XML
  fixture for the Sprint 78A recognizer. Hand-edited to mirror the
  shape observed during Sprint 77 manual testing of the public
  TC ECAD IMPORT V2_2_x.xml; identifying customer / project / site
  data has been replaced with neutral placeholders. NOT a vendor-
  certified Beckhoff schema reference.
-->
<Project>

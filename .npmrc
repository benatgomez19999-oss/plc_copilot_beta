# Sprint 60 — link workspace packages even when their range is plain
# semver (no `workspace:*` prefix). Sprint 60 replaced `workspace:*`
# runtime ranges with explicit "0.1.0" so the published tarballs are
# consumable by `npm install <tgz>` outside the workspace; pnpm needs
# this flag to keep linking the local packages during dev.
link-workspace-packages=true
